DATABASE_URL=
DIAFLOW_API_KEY=
OPENAI_API_KEY=
AUTH_SECRET=
REDIS_DB=
APP_API_KEY=
NEXT_PUBLIC_YOUTUBE_URL=
# Canonical site URL used by the metadata API (src/app/layout.tsx) to
# resolve every relative og:image / og:url into the absolute URLs
# crawlers expect. Set this to the production domain — e.g.
# "https://diaflow.io". On Vercel previews you can leave it unset and
# the layout will fall back to the VERCEL_URL env var; for local dev
# the fallback is http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GA_ID=
KLAVIYO_PRIVATE_API_KEY=

# Google OAuth2 — credentials for the "Continue with Google" button.
# Issue from https://console.cloud.google.com/apis/credentials. The
# authorised redirect URI in the Google console must match
# `${NEXT_PUBLIC_SITE_URL}/api/auth/oauth/google/callback` exactly
# (no trailing slash). Leave blank to disable Google sign-in — the
# email + password flow continues to work.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=