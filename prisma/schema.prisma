generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model EmailCapture {
  id        Int      @id @default(autoincrement())
  email     String
  source    String
  createdAt DateTime @default(now())
  @@map("email_captures")
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  first_email      String?
  passwordHash     String?
  emailVerified    DateTime?
  // Google OAuth2 — set on accounts that signed up via "Continue with
  // Google". `googleId` is the immutable `sub` claim from Google's
  // id_token; `googleEmail` mirrors the account's Google-side address
  // for diagnostics (the canonical address lives in `email`). Both
  // optional so password-only legacy accounts keep working unchanged.
  googleId         String?              @unique
  googleEmail      String?
  recommendedRole  String?
  reason           String?
  ipAddress        String?
  country          String?
  referralCode     String               @unique
  // Inviter lock — once `referredByCode` is set on signup, neither it nor
  // `referredAt` may ever be overwritten by another invite link. Both are
  // assigned exactly once, when the user record is first created. Login,
  // re-request of a magic link, and follow-on POSTs with a different `?ref=`
  // all leave these fields untouched. See guards in:
  //   src/app/api/auth/signup/route.ts
  //   src/app/api/auth/request/route.ts
  referredByCode   String?
  referredAt       DateTime?
  referredBy       User?                @relation("UserReferrals", fields: [referredByCode], references: [referralCode])
  referrals        User[]               @relation("UserReferrals")
  totalInvites     Int                  @default(0)
  // Current floor — FK into Floor.id. Column kept as `currentFloor` to
  // avoid renaming ~50 references across the codebase. The `floor`
  // relation gives access to invitesRequired / label / maxTeammates
  // / item list via DB join instead of hardcoded constants.
  currentFloor     Int                  @default(1)
  floor            Floor                @relation(fields: [currentFloor], references: [id])
  teamName         String?
  teamPurpose      String?
  // Floor sharing — when true, anyone hitting /floor/<referralCode>
  // can view this user's floor and interact (poke teammates). Default
  // false so floors are private until the user opts in.
  publicVisible    Boolean              @default(false)
  authTokens       AuthToken[]
  inviteEvents     InviteEvent[]        @relation("InviterEvents")
  recruitedTeams   RecruitedTeammate[]
  // Per-user item position overrides for the user's own room.
  // Shape: Record<string, [number, number, number]> where the key
  // is either the canonical item key (`couch`, `floor_lamp`) or
  // `${itemKey}_${index}` for multi-instance items
  // (`basic_chair_desk_0`, `_1`, `_2`). Null/empty = use the canonical
  // defaults from FloorItems.tsx ITEMS array.
  itemPositions    Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([referralCode])
  @@map("users")
}

model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId, type])
  @@map("auth_tokens")
}

enum TokenType {
  MAGIC_LINK
  OTP
  EMAIL_VERIFY
  PASSWORD_RESET
}

model InviteEvent {
  id            String   @id @default(cuid())
  inviterUserId String
  inviter       User     @relation("InviterEvents", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitedEmail  String
  invitedUserId String?
  ipAddress     String?
  userAgent     String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([inviterUserId])
  @@index([invitedEmail])
  @@map("invite_events")
}

// Floor — admin-editable config row. One per tower floor (id 1..20 in
// the seed, but new floors can be added without schema changes).
//
// `invitesRequired` is the cumulative invite count needed to reach this
// floor. `maxTeammates` is the cap shown in MySquadDrawer (includes the
// 3 default NPCs). `items` is the set of items unlocked AT this floor;
// a user on floor N has all items from floors 1..N (handled in the
// query side, not stored per-user).
model Floor {
  id              Int          @id
  invitesRequired Int
  label           String
  maxTeammates    Int
  product_reward  String?
  // Each floor can unlock multiple items in a single beat (e.g. F1
  // unlocks BOTH the picture frame AND the office desk). Stored as a
  // Postgres text array so consumers can render each entry as its
  // own badge / cell without parsing a delimiter. Empty `[]` is the
  // valid "no special unlock copy" case.
  unlock_items   String[]    @default([])
  items           FloorItem[]
  users           User[]
  @@map("floor")
}

// Item — the catalogue of decor items that can be placed on floors.
// Keys (`company_picture_frame`, `floor_lamp`, ...) match the scene
// renderer in src/components/scene/environment/FloorItems.tsx — do not
// change them without updating the renderer.
model Item {
  id     Int         @id @default(autoincrement())
  key    String      @unique
  label  String
  floors FloorItem[]
  @@map("items")
}

// FloorItem — many-to-many between Floor and Item. A single floor can
// have multiple items configured (admin tunable). When the user is on
// floor N, the unlocked-item set is `FloorItem WHERE floorId <= N`.
model FloorItem {
  id       Int   @id @default(autoincrement())
  floorId  Int
  itemId   Int
  quantity Int   @default(1)
  floor    Floor @relation(fields: [floorId], references: [id], onDelete: Cascade)
  item     Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([floorId, itemId])
  @@index([floorId])
  @@map("floor_items")
}

model RecruitedTeammate {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // `slug` is set for the 3 default NPCs (`iris`, `mia`, `leo`) so the
  // frontend can look up their visual config (animations, colors,
  // position) from characters.config.ts. Null for user-recruited
  // teammates which use generic appearance.
  slug       String?
  name       String
  role       String
  pokes      Int      @default(0)
  // True for the 3 seeded default NPCs — these rows can't be renamed
  // or deleted via /api/recruit/[id]. Enforced in the route handlers.
  isDefault  Boolean  @default(false)
  // "Launch-day promise" — the per-role one-liner the speech bubble
  // surfaces ("I will handle your calendar, draft emails…"). Populated
  // by the Diaflow process API (builder a7eSxQk9eE) on create + on
  // role-change. Stays null while the background fetch is in flight
  // after a bulk add — the bubble falls back to a generic line in
  // that case. Always sourced from the RoleDescription cache so two
  // teammates with the same role share the same sentence.
  description String?
  createdAt  DateTime @default(now())

  // One slug per user (defaults are unique per user; nullable slug
  // allows many custom teammates to coexist since Postgres treats
  // NULLs as distinct in a unique index).
  @@unique([userId, slug])
  @@index([userId])
  @@map("recruited_teammates")
}

// RoleDescription — per-role cache for the "what this teammate will
// do" sentence returned by the Diaflow process API. The Primary key
// is the LOWERCASED role string so capitalisation variants ("CEO" vs
// "ceo" vs "Ceo") all hit the same row — bulk adds with mixed casing
// shouldn't billed for duplicate API calls.
//
// `description` stores the API output verbatim (already trimmed). The
// only consumer is /api/recruit + /api/recruit/[id], which read the
// row to populate RecruitedTeammate.description.
model RoleDescription {
  // Lowercased role text — the cache key. Always lookup with
  // `role.trim().toLowerCase()`.
  role        String   @id
  // Original casing — handy for analytics + admin tooling. Not used
  // for lookups.
  displayRole String
  // The Diaflow API output, e.g. "I will handle your calendar,
  // draft emails, and chase follow-ups."
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("role_descriptions")
}
